0000 8014 ; LD 0x014 - Carrega W no acumulador
0002 1018 ; JZ 0x018 - Se W=0, pula os dados e vai para o erro
0004 8010 ; LD 0x010 - Caso contrario, carrega X
0006 5012 ; SUB 0x012 - Subtrai Y (X - Y)
0008 7014 ; DIV 0x014 - Divide por W
000A 9016 ; MM 0x016 - Armazena o resultado em Z
000C C000 ; HM 0x000 - Interrompe a execucao
0010 0000 ; X
0012 0000 ; Y
0014 0000 ; W
0016 0000 ; Z
0018 3001 ; LV 0x001 - Erro: carrega 1
001A 000A ; JP 0x00A - Retorna fluxo para gravar em Z